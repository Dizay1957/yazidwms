# PostgreSQL container
POSTGRES_DB=yazidwms
POSTGRES_USER=yazid
POSTGRES_PASSWORD=change-this-postgres-password

# pgAdmin container
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=change-this-pgadmin-password

# Spring Boot application
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080
DB_HOST=postgres
DB_PORT=5432
DB_NAME=yazidwms
DB_USERNAME=yazid
DB_PASSWORD=change-this-postgres-password

# Security
JWT_SECRET=replace-with-a-long-random-development-secret-at-least-32-characters
JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=7
RATE_LIMIT_PER_MINUTE=120

# Seeded local admin
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-this-admin-password
SEED_DEMO_DATA=false

# Notifications and local mail testing
NOTIFICATION_ADMIN_EMAIL=admin@example.com
MAIL_HOST=mailhog
MAIL_PORT=1025

# API documentation
SWAGGER_ENABLED=true
